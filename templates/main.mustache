    @template  local_group_monitoring/main

    Main page template for the Group Monitoring plugin.

    Context variables required:
    - courseid         int     Current course ID.
    - sesskey          string  Moodle session key.
    - coursename       string  Course full name.
    - courseshortname  string  Course short name.
    - tab_dashboard    bool    Is the dashboard tab active?
    - tab_courses      bool    Is the courses tab active?
    - tab_groups       bool    Is the groups tab active?
    - tab_polos        bool    Is the polos tab active?
    - tab_tutors       bool    Is the tutors tab active?
    - totalcourses     int     Metric: total courses.
    - totalgroups      int     Metric: total groups.
    - totalpolos       int     Metric: total polos.
    - totaltutors      int     Metric: total tutors/members.
    - cancreategroup   bool    Can current user create groups?
    - canaddmember     bool    Can current user add members?
    - cancreatetutor   bool    Can current user create tutors?
    - canmanagepolo    bool    Can current user manage polos?
    - list_groups      array   Monitored group objects.
    - list_polos       array   Polo name objects.
    - list_tutors      array   Tutor user objects.
    - list_roles       array   Role objects (id, name).

    @package    local_group_monitoring
    @copyright  2026 Consulguia
    @license    http://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="container-fluid mt-3" id="groupmon-container"
     data-courseid="{{courseid}}" data-sesskey="{{sesskey}}">

    {{! ---- Page header ---- }}
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="mb-0 font-weight-bold">
                {{#tab_dashboard}}{{# str }} tab_dashboard, local_group_monitoring {{/ str }}{{/tab_dashboard}}
                {{#tab_courses}}{{# str }} courses, local_group_monitoring {{/ str }}{{/tab_courses}}
                {{#tab_groups}}{{# str }} groups, local_group_monitoring {{/ str }}{{/tab_groups}}
                {{#tab_polos}}{{# str }} polos, local_group_monitoring {{/ str }}{{/tab_polos}}
                {{#tab_tutors}}{{# str }} tutors, local_group_monitoring {{/ str }}{{/tab_tutors}}
            </h2>
            <p class="text-muted">{{# str }} subtitle, local_group_monitoring {{/ str }}</p>
        </div>
        <div>
            {{#tab_groups}}{{#cancreategroup}}
                <button id="btn-new-group" class="btn btn-primary">
                    <i class="fa fa-plus mr-1"></i>
                    {{# str }} creategroup, local_group_monitoring {{/ str }}
                </button>
            {{/cancreategroup}}{{/tab_groups}}
            {{#tab_polos}}{{#canmanagepolo}}
                <button id="btn-new-polo" class="btn btn-primary">
                    <i class="fa fa-plus mr-1"></i>
                    {{# str }} btn_polo, local_group_monitoring {{/ str }}
                </button>
            {{/canmanagepolo}}{{/tab_polos}}
            {{#tab_tutors}}{{#cancreatetutor}}
                <button id="btn-new-tutor" class="btn btn-primary">
                    <i class="fa fa-plus mr-1"></i>
                    {{# str }} btn_tutor, local_group_monitoring {{/ str }}
                </button>
            {{/cancreatetutor}}{{/tab_tutors}}
        </div>
    </div>

    {{! ---- Tab navigation ---- }}
    <ul class="nav nav-pills mb-4">
        <li class="nav-item">
            <a class="nav-link {{#tab_dashboard}}active font-weight-bold{{/tab_dashboard}} px-4"
               href="?courseid={{courseid}}&tab=dashboard">
                <i class="fa fa-th-large mr-2"></i>{{# str }} tab_dashboard, local_group_monitoring {{/ str }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_courses}}active font-weight-bold{{/tab_courses}} px-4"
               href="?courseid={{courseid}}&tab=courses">
                <i class="fa fa-book mr-2"></i>{{# str }} courses, local_group_monitoring {{/ str }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_tutors}}active font-weight-bold{{/tab_tutors}} px-4"
               href="?courseid={{courseid}}&tab=tutors">
                <i class="fa fa-graduation-cap mr-2"></i>{{# str }} tutors, local_group_monitoring {{/ str }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_groups}}active font-weight-bold{{/tab_groups}} px-4"
               href="?courseid={{courseid}}&tab=groups">
                <i class="fa fa-users mr-2"></i>{{# str }} groups, local_group_monitoring {{/ str }}
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{#tab_polos}}active font-weight-bold{{/tab_polos}} px-4"
               href="?courseid={{courseid}}&tab=polos">
                <i class="fa fa-map-marker mr-2"></i>{{# str }} polos, local_group_monitoring {{/ str }}
            </a>
        </li>
    </ul>

    {{! ---- Tab content ---- }}
    <div class="tab-content bg-transparent border-0">

        {{! ---- Dashboard tab ---- }}
        {{#tab_dashboard}}
        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex align-items-center">
                        <div class="p-3 bg-light rounded text-primary mr-3">
                            <i class="fa fa-book fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="mb-0">{{totalcourses}}</h3>
                            <small class="text-muted">{{# str }} courses, local_group_monitoring {{/ str }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex align-items-center">
                        <div class="p-3 bg-light rounded text-warning mr-3">
                            <i class="fa fa-users fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="mb-0">{{totalgroups}}</h3>
                            <small class="text-muted">{{# str }} groups, local_group_monitoring {{/ str }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex align-items-center">
                        <div class="p-3 bg-light rounded text-secondary mr-3">
                            <i class="fa fa-map-marker fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="mb-0">{{totalpolos}}</h3>
                            <small class="text-muted">{{# str }} polos, local_group_monitoring {{/ str }}</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body d-flex align-items-center">
                        <div class="p-3 bg-light rounded text-danger mr-3">
                            <i class="fa fa-graduation-cap fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="mb-0">{{totaltutors}}</h3>
                            <small class="text-muted">{{# str }} students, local_group_monitoring {{/ str }}</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/tab_dashboard}}

        {{! ---- Courses tab ---- }}
        {{#tab_courses}}
        <div class="card shadow-sm border-0 mb-3 col-md-6">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="p-2 bg-light text-primary rounded mr-3">
                        <i class="fa fa-book"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 font-weight-bold">{{coursename}}</h5>
                        <small class="text-muted">{{courseshortname}}</small>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge badge-secondary p-2">
                        <i class="fa fa-users mr-1"></i>
                        {{# str }} current_course, local_group_monitoring {{/ str }}
                    </span>
                </div>
            </div>
        </div>
        {{/tab_courses}}

        {{! ---- Groups tab ---- }}
        {{#tab_groups}}
        <div class="row">
            {{#list_groups}}
            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="p-2 bg-light text-primary rounded mr-3">
                                <i class="fa fa-users"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 font-weight-bold">{{name}}</h5>
                                <small class="text-muted">
                                    {{membercount}} {{# str }} students_linked, local_group_monitoring {{/ str }}
                                </small>
                            </div>
                        </div>
                        <div class="mb-3">
                            <span class="badge badge-light border mr-1">{{polo}}</span>
                        </div>
                        <div class="bg-light p-2 rounded mb-3">
                            <h6 class="small font-weight-bold text-muted text-uppercase mb-2">
                                {{# str }} members, local_group_monitoring {{/ str }}
                            </h6>
                            {{#has_members}}
                            <ul class="list-unstyled mb-0 small">
                                {{#members}}
                                <li class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                    <span class="text-dark">
                                        <i class="fa fa-user-o mr-1"></i>
                                        {{firstname}} {{lastname}} ({{username}})
                                    </span>
                                    <span class="badge badge-secondary">{{added_via}}</span>
                                </li>
                                {{/members}}
                            </ul>
                            {{/has_members}}
                            {{^has_members}}
                            <div class="small text-muted">
                                {{# str }} no_members, local_group_monitoring {{/ str }}
                            </div>
                            {{/has_members}}
                        </div>
                        {{#canaddmember}}
                        <div class="border-top pt-3 d-flex justify-content-between">
                            <button class="btn btn-sm btn-outline-primary btn-add-manual"
                                    data-groupid="{{id}}" data-groupname="{{name}}">
                                <i class="fa fa-user-plus mr-1"></i>
                                {{# str }} addmember, local_group_monitoring {{/ str }}
                            </button>
                            <button class="btn btn-sm btn-outline-secondary btn-add-csv"
                                    data-groupid="{{id}}" data-groupname="{{name}}">
                                <i class="fa fa-upload mr-1"></i>
                                {{# str }} importcsv, local_group_monitoring {{/ str }}
                            </button>
                        </div>
                        {{/canaddmember}}
                    </div>
                </div>
            </div>
            {{/list_groups}}
            {{^list_groups}}
            <div class="col-12">
                <div class="alert alert-info">
                    {{# str }} no_groups, local_group_monitoring {{/ str }}
                </div>
            </div>
            {{/list_groups}}
        </div>
        {{/tab_groups}}

        {{! ---- Polos tab ---- }}
        {{#tab_polos}}
        <div class="row">
            {{#list_polos}}
            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-light text-primary rounded mr-3">
                                <i class="fa fa-map-marker"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 font-weight-bold">{{name}}</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/list_polos}}
            {{^list_polos}}
            <div class="col-12">
                <div class="alert alert-info">
                    {{# str }} no_polos, local_group_monitoring {{/ str }}
                </div>
            </div>
            {{/list_polos}}
        </div>
        {{/tab_polos}}

        {{! ---- Tutors tab ---- }}
        {{#tab_tutors}}
        <div class="row">
            {{#list_tutors}}
            <div class="col-md-6">
                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-light text-primary rounded mr-3 font-weight-bold">
                                <i class="fa fa-user"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 font-weight-bold">{{firstname}} {{lastname}}</h5>
                                <small class="text-muted">{{email}}</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/list_tutors}}
            {{^list_tutors}}
            <div class="col-12">
                <div class="alert alert-info">
                    {{# str }} no_tutors, local_group_monitoring {{/ str }}
                </div>
            </div>
            {{/list_tutors}}
        </div>
        {{/tab_tutors}}

    </div>{{! end tab-content }}
</div>{{! end groupmon-container }}

{{! Hidden data containers for AMD modal forms }}
<div id="hidden-roles" style="display:none;">
    {{#list_roles}}<option value="{{id}}">{{name}}</option>{{/list_roles}}
</div>
<div id="hidden-polos" style="display:none;">
    {{#list_polos}}<option value="{{name}}">{{name}}</option>{{/list_polos}}
</div>
<div id="hidden-tutors" style="display:none;">
    {{#list_tutors}}<option value="{{id}}">{{firstname}} {{lastname}}</option>{{/list_tutors}}
</div>
<datalist id="polo-list">
    {{#list_polos}}<option value="{{name}}"></option>{{/list_polos}}
</datalist>

{{! Initialise the AMD modal module - all string handling is inside the module }}
{{#js}}
require(['local_group_monitoring/modals'], function(Modals) {
    Modals.init();
});
{{/js}}
